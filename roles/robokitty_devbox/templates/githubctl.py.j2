def cmd_pr_checks(args) -> int:
    ensure_json_format(args)
    cfg = load_config()
    repo = repo_cfg(cfg, args.repo)
    gh_token = token()
    view_cp = run_result([
        'gh', 'pr', 'view', str(args.number), '--repo', repo['full_name'],
        '--json', 'statusCheckRollup',
    ], token=gh_token, for_gh=True)
    if view_cp.returncode == 0:
        try:
            payload = json.loads(view_cp.stdout.decode() or '{}')
        except json.JSONDecodeError as ex:
            raise RuntimeError('gh pr view returned invalid JSON for checks') from ex
        json_out({
            'ok': True,
            'repo': repo['full_name'],
            'pr_number': args.number,
            'source': 'gh-pr-view-statusCheckRollup',
            'checks': payload.get('statusCheckRollup', []),
        })
        return 0

    fallback_cp = run_result([
        'gh', 'pr', 'checks', str(args.number), '--repo', repo['full_name'],
    ], token=gh_token, for_gh=True)
    raw = fallback_cp.stdout.decode(errors='replace').strip()
    if fallback_cp.returncode == 0 or raw:
        json_out({
            'ok': True,
            'repo': repo['full_name'],
            'pr_number': args.number,
            'source': 'gh-pr-checks-text',
            'gh_returncode': fallback_cp.returncode,
            'raw': raw,
            'view_error': view_cp.stderr.decode(errors='replace')[:2000].strip(),
        })
        return 0

    raise RuntimeError(
        'failed to read PR checks\n'
        f'pr view stderr={view_cp.stderr.decode(errors="replace")[:2000].strip()}\n'
        f'pr checks stderr={fallback_cp.stderr.decode(errors="replace")[:2000].strip()}'
    )


def cmd_pr_comment(args) -> int:
    ensure_json_format(args)
    cfg = load_config()
    repo = repo_cfg(cfg, args.repo)
    body_file = materialize_body_file(args.body_file)
    gh_token = token()
    try:
        run([
            'gh', 'pr', 'comment', str(args.number), '--repo', repo['full_name'],
            '--body-file', str(body_file),
        ], token=gh_token, for_gh=True)
        json_out({'ok': True, 'repo': repo['full_name'], 'pr_number': args.number})
        return 0
    finally:
        shutil.rmtree(body_file.parent, ignore_errors=True)
        cleanup_prepared_file(args.body_file)


def requires_required_audit(args) -> bool:
    if getattr(args, 'cmd', None) == 'submit':
        return True
    return getattr(args, 'cmd', None) == 'pr' and getattr(args, 'prcmd', None) == 'comment'


def main(argv=None) -> int:
    p = argparse.ArgumentParser(prog='githubctl')
    sub = p.add_subparsers(dest='cmd', required=True)

    s = sub.add_parser('status')
    s.add_argument('--repo', required=True)
    s.add_argument('--format', default='json', choices=['json'])
    s.set_defaults(func=cmd_status)

    s = sub.add_parser('audit')
    s.add_argument('--limit', type=audit_limit, default=20)
    s.add_argument('--format', default='json', choices=['json'])
    s.set_defaults(func=cmd_audit)

    s = sub.add_parser('repo')
    reposub = s.add_subparsers(dest='repocmd', required=True)
    sync = reposub.add_parser('sync')
    sync.add_argument('--repo', required=True)
    sync.add_argument('--format', default='json', choices=['json'])
    sync.set_defaults(func=cmd_repo_sync)

    s = sub.add_parser('submit')
    s.add_argument('--repo', required=True)
    s.add_argument('--worktree', required=True)
    s.add_argument('--branch', required=True)
    s.add_argument('--base', required=True)
    s.add_argument('--title', required=True)
    s.add_argument('--body-file', required=True)
    s.add_argument('--patch-file', help=argparse.SUPPRESS)
    s.add_argument(
        '--draft',
        action='store_true',
        default={{ robokitty_github_default_pr_draft | bool | ternary('True', 'False') }},
    )
    s.add_argument('--format', default='json', choices=['json'])
    s.set_defaults(func=cmd_submit)

    s = sub.add_parser('pr')
    prsub = s.add_subparsers(dest='prcmd', required=True)

    v = prsub.add_parser('view')
    v.add_argument('--repo', required=True)
    v.add_argument('--number', type=positive_int, required=True)
    v.add_argument('--format', default='json', choices=['json'])
    v.set_defaults(func=cmd_pr_view)

    c = prsub.add_parser('checks')
    c.add_argument('--repo', required=True)
    c.add_argument('--number', type=positive_int, required=True)
    c.add_argument('--format', default='json', choices=['json'])
    c.set_defaults(func=cmd_pr_checks)

    m = prsub.add_parser('comment')
    m.add_argument('--repo', required=True)
    m.add_argument('--number', type=positive_int, required=True)
    m.add_argument('--body-file', required=True)
    m.add_argument('--format', default='json', choices=['json'])
    m.set_defaults(func=cmd_pr_comment)

    args = p.parse_args(argv)
    required_audit = requires_required_audit(args)
    try:
        if required_audit:
            audit(args, True, phase='start', required=True)
        rc = args.func(args)
        audit(args, rc == 0, required=False)
        return rc
    except AuditError as ex:
        cleanup_prepared_file(getattr(args, 'patch_file', None))
        cleanup_prepared_file(getattr(args, 'body_file', None))
        json_out({'ok': False, 'error': str(ex), 'type': 'audit'})
        return 5
    except ValueError as ex:
        audit(args, False, 'validation', required=False)
        json_out({'ok': False, 'error': str(ex), 'type': 'validation'})
        return 1
    except Exception as ex:
        # Do not include env vars/tokens. Keep error bounded.
        audit(args, False, 'execution', required=False)
        json_out({'ok': False, 'error': str(ex)[:2000], 'type': 'execution'})
        return 4

if __name__ == '__main__':
    raise SystemExit(main())
