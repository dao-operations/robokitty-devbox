---
robokitty_hostname: robokitty-devbox

# Until pinned installer checksums are documented, P0 bootstrap requires an
# explicit inventory-level acceptance for the upstream installer scripts.
# Prefer setting robokitty_*_installer_checksum when available.
robokitty_codex_installer_allow_unverified: true
robokitty_codex_installer_unverified_reason: >-
  P0 bootstrap accepts the upstream Codex installer script until a pinned artifact is documented.
robokitty_uv_installer_allow_unverified: true
robokitty_uv_installer_unverified_reason: >-
  P0 bootstrap accepts the upstream uv installer script until a pinned artifact is documented.
robokitty_takopi_allow_unpinned: true
robokitty_takopi_unpinned_reason: "P0 bootstrap accepts latest Takopi until a version pin is selected."

robokitty_takopi_chat_id: null
robokitty_takopi_allowed_user_ids:
  - 123456789

robokitty_github_app_id: ""
robokitty_github_app_installation_id: ""
# Preferred: keep private key outside git and copy it from your local machine during playbook run.
robokitty_github_app_private_key_src: ""

robokitty_repos:
  - alias: dao
    owner: example-org
    repo: example-frontend
    default_branch: main
    clone_url: https://github.com/example-org/example-frontend.git
    path: /srv/robokitty-devbox/work/example-frontend
    allowed_base_branches:
      - main
    allow_push: true
    allow_pr_create: true
    container_image: docker.io/library/node:22-bookworm
    pr_labels:
      - agent
      - needs-review

robokitty_infra_repo:
  alias: robokitty-infra
  owner: example-org
  repo: robokitty-devbox
  default_branch: main
  clone_url: https://github.com/example-org/robokitty-devbox.git
  path: /srv/robokitty-devbox/infra
  allowed_base_branches:
    - main
  allow_push: true
  allow_pr_create: true
  container_image: docker.io/library/ubuntu:24.04
