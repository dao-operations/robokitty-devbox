#!/usr/bin/env python3
"""Prepare githubctl inputs before crossing to agent-git.

Runs as the Codex runner user. It may execute Git in runner-owned worktrees;
the agent-git broker must not.
"""
from __future__ import annotations

import argparse
import grp
import json
import os
import pwd
import re
import shutil
import socket
import stat
import subprocess
import sys
import tempfile
from pathlib import Path

BODY_FILE_MAX_BYTES = 256 * 1024
BRANCH_RE = re.compile(r'^agent/[A-Za-z0-9._-]+$')
REF_NAME_RE = re.compile(r'^[A-Za-z0-9._/-]+$')
SECRET_SUFFIXES = {'.key', '.pem', '.p12', '.pfx'}
HANDOFF_GROUP = '{{ robokitty_github_broker_handoff_group }}'
SOCKET_PATH = '{{ robokitty_github_broker_socket_path }}'
EXCHANGE_DIR = Path('{{ robokitty_github_broker_exchange_dir }}')
CONFIG = Path('{{ robokitty_repo_config_file }}')
WORKTREE_SOURCE_DIR = Path('{{ robokitty_worktree_source_dir }}')
RUNNER_USER = '{{ robokitty_runner_user }}'
MAX_RESPONSE_BYTES = 25 * 1024 * 1024


def run(argv: list[str], *, cwd: Path | None = None, input_bytes: bytes | None = None) -> subprocess.CompletedProcess:
    cp = subprocess.run(
        argv,
        cwd=str(cwd) if cwd else None,
        input=input_bytes,
        capture_output=True,
        check=False,
        env={
            'PATH': '/usr/local/bin:/usr/bin:/bin',
            'HOME': str(Path.home()),
            'LANG': 'C.UTF-8',
            'LC_ALL': 'C.UTF-8',
            'GIT_TERMINAL_PROMPT': '0',
        },
    )
    if cp.returncode != 0:
        err = cp.stderr.decode(errors='replace')[:2000]
        out = cp.stdout.decode(errors='replace')[:1000]
        raise RuntimeError(f"command failed: {argv[0]} rc={cp.returncode}\nstdout={out}\nstderr={err}")
    return cp


def validate_branch(branch: str) -> None:
    if not BRANCH_RE.match(branch) or '..' in branch or branch.endswith('/'):
        raise ValueError('branch must match agent/[A-Za-z0-9._-]+')
    if branch in {'agent/main', 'agent/master', 'agent/prod', 'agent/production'}:
        raise ValueError('branch name too close to protected branch')


def validate_repo_branch(branch: str) -> None:
    if not branch or not REF_NAME_RE.match(branch):
        raise ValueError(f'repo branch has unsafe characters: {branch}')
    if branch.startswith('/') or branch.endswith('/') or '..' in branch or '@{' in branch:
        raise ValueError(f'repo branch has unsafe path components: {branch}')


def load_config() -> dict:
    return json.loads(CONFIG.read_text(encoding='utf-8'))


def repo_cfg(cfg: dict, alias: str) -> dict:
    repos = cfg.get('repos', {})
    if alias not in repos:
        raise ValueError(f'unknown repo alias: {alias}')
    return repos[alias]


def safe_absolute_path(path: Path, label: str) -> Path:
    raw = str(path)
    if not raw.startswith('/'):
        raise ValueError(f'{label} must be absolute')
    if not re.match(r'^/[A-Za-z0-9._+/-]+$', raw):
        raise ValueError(f'{label} contains unsafe characters')
    if '..' in path.parts:
        raise ValueError(f'{label} contains unsafe path components')
    return path


def path_is_under(path: Path, parent: Path) -> bool:
    try:
        path.relative_to(parent)
    except ValueError:
        return False
    return True


def git_common_dir(repo: Path) -> Path:
    raw = run(['git', '-C', str(repo), 'rev-parse', '--git-common-dir']).stdout.decode().strip()
    path = Path(raw)
    if not path.is_absolute():
        path = repo / path
    return path.resolve()


def validate_sync_bundle(path_arg: str) -> Path:
    bundle = Path(path_arg)
    if not bundle.is_absolute():
        raise ValueError('broker returned a relative bundle path')
    if bundle.parent.parent != EXCHANGE_DIR or not bundle.parent.name.startswith('robokitty-sync.'):
        raise ValueError('broker returned an unexpected bundle path')
    st = bundle.lstat()
    if stat.S_ISLNK(st.st_mode) or not stat.S_ISREG(st.st_mode):
        raise ValueError('broker bundle must be a regular file')
    return bundle


def bundle_refs(bundle: Path) -> list[str]:
    output = run(['git', 'bundle', 'list-heads', str(bundle)]).stdout.decode().splitlines()
    refs: list[str] = []
    for line in output:
        parts = line.split()
        if len(parts) >= 2 and parts[1].startswith('refs/'):
            refs.append(parts[1])
    if not refs:
        raise ValueError('broker bundle contains no refs')
    return refs


def import_sync_bundle(source_path: Path, bundle: Path, default_branch: str) -> str:
    refs = bundle_refs(bundle)
    imported = False
    for prefix in ('refs/remotes/origin/', 'refs/heads/'):
        for ref in refs:
            if not ref.startswith(prefix):
                continue
            branch = ref[len(prefix):]
            validate_repo_branch(branch)
            run([
                'git', '-C', str(source_path), 'fetch', '--prune', str(bundle),
                f'{ref}:refs/remotes/origin/{branch}',
            ])
            imported = True
    if not imported:
        raise ValueError('broker bundle contains no importable branch refs')

    base_ref = f'refs/remotes/origin/{default_branch}'
    try:
        return run([
            'git', '-C', str(source_path), 'rev-parse', '--verify',
            base_ref + '^{commit}',
        ]).stdout.decode().strip()
    except RuntimeError as ex:
        raise RuntimeError(f'brokered sync did not provide default branch ref: {base_ref}') from ex


def validate_body_file(path_arg: str, worktree: Path) -> Path:
    raw = Path(path_arg)
    if raw.is_absolute() or '..' in raw.parts:
        raise ValueError('body-file must be relative and stay inside the worktree')
    body_file = (worktree / raw).resolve()
    worktree = worktree.resolve()
    if not str(body_file).startswith(str(worktree) + os.sep):
        raise ValueError('body-file must stay inside the worktree')
    if body_file.suffix.lower() in SECRET_SUFFIXES or body_file.name.startswith('.env'):
        raise ValueError('body-file looks secret-like')
    if not body_file.is_file():
        raise ValueError('body-file is not a regular file')
    if body_file.stat().st_size > BODY_FILE_MAX_BYTES:
        raise ValueError('body-file is too large')
    return body_file


def handoff_group_gid() -> int:
    gid = grp.getgrnam(HANDOFF_GROUP).gr_gid
    if gid != os.getegid() and gid not in os.getgroups():
        raise RuntimeError(
            f'process is not in {HANDOFF_GROUP}; Codex must run as '
            'the managed runner user with the broker handoff group'
        )
    return gid


def require_runner_context() -> None:
    try:
        runner_uid = pwd.getpwnam(RUNNER_USER).pw_uid
    except KeyError as ex:
        raise RuntimeError(f'runner user is unavailable: {RUNNER_USER}') from ex
    if os.geteuid() != runner_uid:
        raise RuntimeError(
            f'repo sync must run as {RUNNER_USER}; use: '
            f'sudo -u {RUNNER_USER} -- githubctl repo sync --repo <alias> --format json'
        )
    handoff_group_gid()


def make_exchange_dir() -> Path:
    try:
        exchange_stat = EXCHANGE_DIR.lstat()
    except OSError as ex:
        raise RuntimeError(f'broker exchange directory is unavailable: {ex}') from ex
    if not stat.S_ISDIR(exchange_stat.st_mode) or stat.S_ISLNK(exchange_stat.st_mode):
        raise RuntimeError('broker exchange path must be a real directory')
    path = Path(tempfile.mkdtemp(prefix='robokitty-submit.', dir=str(EXCHANGE_DIR)))
    gid = handoff_group_gid()
    os.chown(path, -1, gid)
    os.chmod(path, 0o770)
    return path


def write_exchange_file(path: Path, data: bytes) -> None:
    path.write_bytes(data)
    gid = handoff_group_gid()
    os.chown(path, -1, gid)
    os.chmod(path, 0o660)


def base_ref(worktree: Path, base: str) -> str:
    candidates = [f'origin/{base}', base]
    for candidate in candidates:
        cp = subprocess.run(
            ['git', '-C', str(worktree), 'rev-parse', '--verify', candidate + '^{commit}'],
            capture_output=True,
            check=False,
        )
        if cp.returncode == 0:
            return candidate
    raise ValueError(f'base branch not available locally: {base}')


def dirty_status_entries(worktree: Path, allowed_untracked_file: Path) -> list[str]:
    rel_allowed = allowed_untracked_file.relative_to(worktree).as_posix()
    status = run([
        'git', '-C', str(worktree), 'status', '--porcelain=v1',
        '--untracked-files=all', '-z',
    ]).stdout
    dirty: list[str] = []
    entries = status.split(b'\0')
    index = 0
    while index < len(entries):
        entry = entries[index]
        if not entry:
            index += 1
            continue
        text = entry.decode('utf-8', errors='surrogateescape')
        code = text[:2]
        path = text[3:] if len(text) > 3 else ''
        if not (code == '??' and path == rel_allowed):
            dirty.append(text)
        if 'R' in code or 'C' in code:
            index += 1
        index += 1
    return dirty


def prepare_submit(args: argparse.Namespace) -> list[str]:
    validate_branch(args.branch)
    worktree = Path(args.worktree).resolve()
    body_file = validate_body_file(args.body_file, worktree)
    branch = run(['git', '-C', str(worktree), 'branch', '--show-current']).stdout.decode().strip()
    if branch != args.branch:
        raise ValueError(f'worktree is on {branch}, expected {args.branch}')
    if dirty_status_entries(worktree, body_file):
        raise ValueError(
            'worktree has uncommitted changes other than body-file; '
            'commit locally before submit'
        )
    ref = base_ref(worktree, args.base)
    patch = run([
        'git', '-C', str(worktree), '--no-pager', 'diff', '--binary',
        '--no-ext-diff', '--no-textconv', f'{ref}...HEAD',
    ]).stdout
    if not patch.strip():
        raise ValueError('empty diff; nothing to submit')

    exchange = make_exchange_dir()
    patch_file = exchange / 'changes.patch'
    prepared_body = exchange / 'body.md'
    write_exchange_file(patch_file, patch)
    write_exchange_file(prepared_body, body_file.read_bytes())

    broker_args = [
        'submit',
        '--repo', args.repo,
        '--worktree', str(worktree),
        '--branch', args.branch,
        '--base', args.base,
        '--title', args.title,
        '--body-file', str(prepared_body),
        '--patch-file', str(patch_file),
        '--format', args.format,
    ]
    if args.draft:
        broker_args.append('--draft')
    return broker_args


def prepare_comment(args: argparse.Namespace) -> list[str]:
    worktree = Path.cwd().resolve()
    body_file = validate_body_file(args.body_file, worktree)
    exchange = make_exchange_dir()
    prepared_body = exchange / 'body.md'
    write_exchange_file(prepared_body, body_file.read_bytes())
    return [
        'pr',
        'comment',
        '--repo', args.repo,
        '--number', str(args.number),
        '--body-file', str(prepared_body),
        '--format', args.format,
    ]


def broker_request(args: list[str]) -> dict:
    request = json.dumps({'argv': args}).encode('utf-8')
    with socket.socket(socket.AF_UNIX, socket.SOCK_STREAM) as sock:
        sock.connect(SOCKET_PATH)
        sock.sendall(request)
        sock.shutdown(socket.SHUT_WR)
        chunks: list[bytes] = []
        total = 0
        while True:
            chunk = sock.recv(65536)
            if not chunk:
                break
            chunks.append(chunk)
            total += len(chunk)
            if total > MAX_RESPONSE_BYTES:
                raise RuntimeError('broker response is too large')
    return json.loads(b''.join(chunks).decode('utf-8'))


def call_broker(args: list[str]) -> int:
    try:
        response = broker_request(args)
    except OSError as ex:
        print(f'githubctl broker unavailable at {SOCKET_PATH}: {ex}', file=sys.stderr)
        return 1
    if response.get('stdout'):
        sys.stdout.write(response['stdout'])
    if response.get('stderr'):
        sys.stderr.write(response['stderr'])
    return int(response.get('rc', 1))


def prepare_repo_sync(args: argparse.Namespace) -> int:
    require_runner_context()
    cfg = load_config()
    repo = repo_cfg(cfg, args.repo)
    if not repo.get('brokered_sync'):
        raise ValueError('repo is not configured for brokered sync')

    response = broker_request(['repo', 'sync', '--repo', args.repo, '--format', args.format])
    if response.get('stderr'):
        sys.stderr.write(response['stderr'])
    if int(response.get('rc', 1)) != 0:
        if response.get('stdout'):
            sys.stdout.write(response['stdout'])
        return int(response.get('rc', 1))

    payload = json.loads(response.get('stdout') or '{}')
    if not payload.get('ok'):
        print(json.dumps(payload, indent=2, sort_keys=True))
        return 1

    bundle = validate_sync_bundle(payload['bundle_file'])
    try:
        root_dir = safe_absolute_path(Path(cfg['root']).resolve(), 'configured root')
        workdir = safe_absolute_path(Path(cfg['workdir']).resolve(), 'configured workdir')
        source_parent = safe_absolute_path(WORKTREE_SOURCE_DIR.resolve(), 'worktree source directory')
        source_path = safe_absolute_path(Path(repo['source_path']).resolve(strict=False), 'repo source path')
        repo_path = safe_absolute_path(Path(repo['path']).resolve(strict=False), 'repo path')
        default_branch = str(repo.get('default_branch', 'main'))

        if source_path.parent.resolve() != source_parent:
            raise ValueError('repo source path must live directly under the worktree source directory')
        if source_path.exists() and source_path.is_symlink():
            raise ValueError('repo source path must not be a symlink')
        if not path_is_under(repo_path, root_dir) or not path_is_under(repo_path, workdir):
            raise ValueError('repo path must live under the managed workdir')
        if repo_path.exists() and repo_path.is_symlink():
            raise ValueError('repo path must not be a symlink')
    except Exception:
        shutil.rmtree(bundle.parent, ignore_errors=True)
        raise

    try:
        source_parent.mkdir(parents=True, exist_ok=True)
        if not source_path.exists():
            run(['git', 'init', '--bare', str(source_path)])
        if not source_path.is_dir():
            raise ValueError('repo source path is not a directory')
        is_bare = run(['git', '-C', str(source_path), 'rev-parse', '--is-bare-repository']).stdout.decode().strip()
        if is_bare != 'true':
            raise ValueError('repo source path is not a bare repository')

        base_commit = import_sync_bundle(source_path, bundle, default_branch)
        existing_origin = subprocess.run(
            ['git', '-C', str(source_path), 'remote', 'get-url', 'origin'],
            capture_output=True,
            check=False,
        )
        if existing_origin.returncode == 0:
            run(['git', '-C', str(source_path), 'remote', 'remove', 'origin'])
        run(['git', '-C', str(source_path), 'remote', 'add', 'origin', str(source_path)])

        repo_path.parent.mkdir(parents=True, exist_ok=True)
        if not repo_path.exists():
            run(['git', '-C', str(source_path), 'worktree', 'add', '-B', default_branch, str(repo_path), base_commit])
        else:
            if not repo_path.is_dir():
                raise ValueError('repo path exists and is not a directory')
            if git_common_dir(repo_path) != source_path.resolve():
                raise ValueError('repo path does not belong to the brokered source repository')
            dirty = run(['git', '-C', str(repo_path), 'status', '--porcelain']).stdout.decode().strip()
            if dirty:
                raise ValueError('repo checkout has uncommitted changes; clean it before brokered sync')
            run(['git', '-C', str(repo_path), 'checkout', '-B', default_branch, base_commit])
            run(['git', '-C', str(repo_path), 'reset', '--hard', base_commit])

        print(json.dumps({
            'ok': True,
            'repo': payload['repo'],
            'alias': args.repo,
            'path': str(repo_path),
            'source_path': str(source_path),
            'default_branch': default_branch,
            'synced_refs': payload.get('synced_refs', []),
        }, indent=2, sort_keys=True))
        return 0
    finally:
        shutil.rmtree(bundle.parent, ignore_errors=True)


def main(argv: list[str] | None = None) -> int:
    parser = argparse.ArgumentParser(prog='githubctl-prep')
    sub = parser.add_subparsers(dest='cmd', required=True)

    submit = sub.add_parser('submit')
    submit.add_argument('--repo', required=True)
    submit.add_argument('--worktree', required=True)
    submit.add_argument('--branch', required=True)
    submit.add_argument('--base', required=True)
    submit.add_argument('--title', required=True)
    submit.add_argument('--body-file', required=True)
    submit.add_argument('--draft', action='store_true')
    submit.add_argument('--format', default='json', choices=['json'])

    status = sub.add_parser('status')
    status.add_argument('--repo', required=True)
    status.add_argument('--format', default='json', choices=['json'])

    audit = sub.add_parser('audit')
    audit.add_argument('--limit', type=int, default=20)
    audit.add_argument('--format', default='json', choices=['json'])

    repo = sub.add_parser('repo')
    reposub = repo.add_subparsers(dest='repocmd', required=True)
    sync = reposub.add_parser('sync')
    sync.add_argument('--repo', required=True)
    sync.add_argument('--format', default='json', choices=['json'])

    pr = sub.add_parser('pr')
    prsub = pr.add_subparsers(dest='prcmd', required=True)
    view = prsub.add_parser('view')
    view.add_argument('--repo', required=True)
    view.add_argument('--number', type=int, required=True)
    view.add_argument('--format', default='json', choices=['json'])
    checks = prsub.add_parser('checks')
    checks.add_argument('--repo', required=True)
    checks.add_argument('--number', type=int, required=True)
    checks.add_argument('--format', default='json', choices=['json'])
    comment = prsub.add_parser('comment')
    comment.add_argument('--repo', required=True)
    comment.add_argument('--number', type=int, required=True)
    comment.add_argument('--body-file', required=True)
    comment.add_argument('--format', default='json', choices=['json'])

    args = parser.parse_args(argv)
    try:
        if args.cmd == 'submit':
            return call_broker(prepare_submit(args))
        if args.cmd == 'status':
            return call_broker(['status', '--repo', args.repo, '--format', args.format])
        if args.cmd == 'audit':
            return call_broker(['audit', '--limit', str(args.limit), '--format', args.format])
        if args.cmd == 'repo' and args.repocmd == 'sync':
            return prepare_repo_sync(args)
        if args.cmd == 'pr' and args.prcmd == 'view':
            return call_broker([
                'pr', 'view', '--repo', args.repo, '--number', str(args.number),
                '--format', args.format,
            ])
        if args.cmd == 'pr' and args.prcmd == 'checks':
            return call_broker([
                'pr', 'checks', '--repo', args.repo, '--number', str(args.number),
                '--format', args.format,
            ])
        if args.cmd == 'pr' and args.prcmd == 'comment':
            return call_broker(prepare_comment(args))
    except Exception as ex:
        print(f'githubctl prep failed: {ex}', file=sys.stderr)
        return 1
    return 2


if __name__ == '__main__':
    raise SystemExit(main())
