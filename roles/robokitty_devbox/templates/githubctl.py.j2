#!/usr/bin/env python3
"""Restricted GitHub broker for Robokitty.

This is intentionally small. It is not a `gh` passthrough.
Runs as agent-git behind a root-managed Unix socket broker. The runner never
receives a persistent GitHub token; this broker reads the third identity PAT
only inside short-lived git/gh subprocess environments.
"""
from __future__ import annotations

import argparse
import json
import os
import re
import shutil
import stat
import subprocess
import tempfile
import time
from collections import deque
from pathlib import Path

CONFIG = Path('{{ robokitty_repo_config_file }}')
TOKEN_FILE = Path('/home/{{ robokitty_git_user }}/.config/robokitty-devbox/github-token')
SIGN_COMMITS = {{ robokitty_git_commit_signing_enabled | bool | ternary('True', 'False') }}
SIGNING_KEY = Path('{{ robokitty_git_signing_key_path }}')
SIGNING_PUBLIC_KEY = Path('{{ robokitty_git_signing_key_path }}.pub')
ASKPASS = Path('{{ robokitty_libdir }}/github-git-askpass.sh')
AUDIT_HOME = Path('/home/{{ robokitty_git_user }}')
AUDIT_CACHE_DIR = AUDIT_HOME / '.cache'
AUDIT_DIR = AUDIT_CACHE_DIR / 'robokitty-devbox'
AUDIT_LOG = AUDIT_DIR / 'githubctl-audit.jsonl'
BODY_FILE_MAX_BYTES = 256 * 1024
PATCH_FILE_MAX_BYTES = 50 * 1024 * 1024
BRANCH_SUFFIX_RE = re.compile(r'^[A-Za-z0-9._-]+$')
REF_NAME_RE = re.compile(r'^[A-Za-z0-9._/-]+$')
SECRET_SUFFIXES = {'.key', '.pem', '.p12', '.pfx'}
PREPARED_FILE_PARENT = Path('{{ robokitty_github_broker_exchange_dir }}')
PREPARED_FILE_PREFIX = str(PREPARED_FILE_PARENT / 'robokitty-submit.')
REPO_SYNC_FILE_PREFIX = str(PREPARED_FILE_PARENT / 'robokitty-sync.')

class AuditError(RuntimeError):
    pass


def open_dir_child(parent_fd: int, name: str, label: str) -> int:
    flags = os.O_RDONLY
    if hasattr(os, 'O_DIRECTORY'):
        flags |= os.O_DIRECTORY
    if hasattr(os, 'O_NOFOLLOW'):
        flags |= os.O_NOFOLLOW
    try:
        return os.open(name, flags, dir_fd=parent_fd)
    except OSError as ex:
        raise AuditError(f'{label} is unsafe: {ex}') from ex


def validate_dir_fd(fd: int, label: str, *, owner_uid: int | None = None, mode: int | None = None) -> None:
    st = os.fstat(fd)
    if not stat.S_ISDIR(st.st_mode):
        raise AuditError(f'{label} is not a directory')
    if owner_uid is not None and st.st_uid != owner_uid:
        raise AuditError(f'{label} owner is unsafe')
    if mode is not None and stat.S_IMODE(st.st_mode) != mode:
        raise AuditError(f'{label} permissions must be {mode:04o}')


def open_audit_dir(*, create: bool) -> int:
    uid = os.geteuid()
    flags = os.O_RDONLY
    if hasattr(os, 'O_DIRECTORY'):
        flags |= os.O_DIRECTORY
    current_fd = os.open('/', flags)
    current_path = Path('/')
    try:
        for part in AUDIT_DIR.parts[1:]:
            current_path = current_path / part
            if create and current_path in {AUDIT_CACHE_DIR, AUDIT_DIR}:
                try:
                    os.mkdir(part, 0o700, dir_fd=current_fd)
                except FileExistsError:
                    pass
            next_fd = open_dir_child(current_fd, part, f'audit path component {current_path}')
            if current_path == AUDIT_HOME:
                validate_dir_fd(next_fd, str(current_path), owner_uid=uid, mode=0o700)
            elif current_path in {AUDIT_CACHE_DIR, AUDIT_DIR}:
                validate_dir_fd(next_fd, str(current_path), owner_uid=uid, mode=0o700)
            else:
                validate_dir_fd(next_fd, str(current_path))
            os.close(current_fd)
            current_fd = next_fd
        return current_fd
    except Exception:
        os.close(current_fd)
        raise


def write_all(fd: int, data: bytes) -> None:
    offset = 0
    while offset < len(data):
        written = os.write(fd, data[offset:])
        if written <= 0:
            raise AuditError('short audit log write')
        offset += written


def append_audit_record(record: dict) -> None:
    old_umask = os.umask(0o077)
    audit_dir_fd = -1
    try:
        audit_dir_fd = open_audit_dir(create=True)
        flags = os.O_WRONLY | os.O_CREAT | os.O_APPEND
        if hasattr(os, 'O_NOFOLLOW'):
            flags |= os.O_NOFOLLOW
        try:
            fd = os.open(AUDIT_LOG.name, flags, 0o600, dir_fd=audit_dir_fd)
        except OSError as ex:
            raise AuditError(f'audit log is unsafe: {ex}') from ex
        try:
            st = os.fstat(fd)
            if not stat.S_ISREG(st.st_mode):
                raise AuditError('audit log is not a regular file')
            if st.st_uid != os.geteuid():
                raise AuditError('audit log owner is unsafe')
            if stat.S_IMODE(st.st_mode) != 0o600:
                raise AuditError('audit log permissions must be 0600')
            line = json.dumps({k: v for k, v in record.items() if v is not None}, sort_keys=True) + '\n'
            write_all(fd, line.encode('utf-8'))
            os.fsync(fd)
        finally:
            os.close(fd)
    finally:
        if audit_dir_fd >= 0:
            os.close(audit_dir_fd)
        os.umask(old_umask)


def audit(args, ok: bool, error_type: str | None = None, phase: str = 'complete', *, required: bool = False) -> None:
    record = {
        'ts': int(time.time()),
        'phase': phase,
        'ok': ok,
        'cmd': getattr(args, 'cmd', None),
        'repocmd': getattr(args, 'repocmd', None),
        'prcmd': getattr(args, 'prcmd', None),
        'repo': getattr(args, 'repo', None),
        'branch': getattr(args, 'branch', None),
        'base': getattr(args, 'base', None),
        'number': getattr(args, 'number', None),
        'error_type': error_type,
        'sudo_user': os.environ.get('SUDO_USER'),
        'sudo_uid': os.environ.get('SUDO_UID'),
    }
    try:
        append_audit_record(record)
    except AuditError:
        if required:
            raise


def ensure_json_format(args) -> None:
    if getattr(args, 'format', 'json') != 'json':
        raise ValueError('only --format json is supported')


def positive_int(raw: str) -> int:
    try:
        value = int(raw)
    except ValueError as ex:
        raise argparse.ArgumentTypeError('must be an integer') from ex
    if value <= 0:
        raise argparse.ArgumentTypeError('must be positive')
    return value


def audit_limit(raw: str) -> int:
    value = positive_int(raw)
    if value > 200:
        raise argparse.ArgumentTypeError('must be at most 200')
    return value


def load_config() -> dict:
    return json.loads(CONFIG.read_text())


def clean_env(token: str | None = None, for_git: bool = False, for_gh: bool = False) -> dict:
    env = {
        'PATH': '/usr/local/bin:/usr/bin:/bin',
        'HOME': '/home/{{ robokitty_git_user }}',
        'LANG': 'C.UTF-8',
        'LC_ALL': 'C.UTF-8',
        'GIT_TERMINAL_PROMPT': '0',
    }
    if token and for_gh:
        env['GH_TOKEN'] = token
        env['GITHUB_TOKEN'] = token
    if token and for_git:
        env['GIT_ASKPASS'] = str(ASKPASS)
        env['AGENT_GITHUB_TOKEN'] = token
    return env


def run(
    argv: list[str],
    *,
    token: str | None = None,
    for_git=False,
    for_gh=False,
    cwd: Path | None = None,
    input_bytes: bytes | None = None,
) -> subprocess.CompletedProcess:
    cp = run_result(
        argv,
        token=token,
        for_git=for_git,
        for_gh=for_gh,
        cwd=cwd,
        input_bytes=input_bytes,
    )
    if cp.returncode != 0:
        err = cp.stderr.decode(errors='replace')[:2000]
        out = cp.stdout.decode(errors='replace')[:1000]
        raise RuntimeError(f"command failed: {argv[0]} rc={cp.returncode}\nstdout={out}\nstderr={err}")
    return cp


def run_result(
    argv: list[str],
    *,
    token: str | None = None,
    for_git=False,
    for_gh=False,
    cwd: Path | None = None,
    input_bytes: bytes | None = None,
) -> subprocess.CompletedProcess:
    return subprocess.run(
        argv,
        cwd=str(cwd) if cwd else None,
        env=clean_env(token, for_git=for_git, for_gh=for_gh),
        input=input_bytes,
        capture_output=True,
        check=False,
    )


def token() -> str:
    flags = os.O_RDONLY
    if hasattr(os, 'O_NOFOLLOW'):
        flags |= os.O_NOFOLLOW
    try:
        fd = os.open(TOKEN_FILE, flags)
    except OSError as ex:
        raise RuntimeError(f'GitHub token file is unavailable: {ex}') from ex
    try:
        st = os.fstat(fd)
        if not stat.S_ISREG(st.st_mode):
            raise RuntimeError('GitHub token path is not a regular file')
        if st.st_uid != os.geteuid():
            raise RuntimeError('GitHub token file owner is unsafe')
        if stat.S_IMODE(st.st_mode) != 0o600:
            raise RuntimeError('GitHub token file permissions must be 0600')
        with os.fdopen(fd, 'r', encoding='utf-8') as fh:
            fd = -1
            t = fh.read().strip()
    finally:
        if fd >= 0:
            os.close(fd)
    if not t:
        raise RuntimeError('empty GitHub token')
    return t


def validate_owned_regular_file(path: Path, label: str, mode: int | None = None) -> None:
    try:
        st = path.lstat()
    except OSError as ex:
        raise RuntimeError(f'{label} is unavailable: {ex}') from ex
    if stat.S_ISLNK(st.st_mode):
        raise RuntimeError(f'{label} must not be a symlink')
    if not stat.S_ISREG(st.st_mode):
        raise RuntimeError(f'{label} must be a regular file')
    if st.st_uid != os.geteuid():
        raise RuntimeError(f'{label} owner is unsafe')
    if mode is not None and stat.S_IMODE(st.st_mode) != mode:
        raise RuntimeError(f'{label} permissions must be {mode:04o}')


def validate_signing_material() -> None:
    if not SIGN_COMMITS:
        return
    validate_owned_regular_file(SIGNING_KEY, 'Git signing private key', 0o600)
    validate_owned_regular_file(SIGNING_PUBLIC_KEY, 'Git signing public key', 0o644)
    public_key = SIGNING_PUBLIC_KEY.read_text(encoding='utf-8').strip()
    if not public_key.startswith((
        'ssh-ed25519 ',
        'ecdsa-sha2-nistp256 ',
        'sk-ssh-ed25519@openssh.com ',
        'sk-ecdsa-sha2-nistp256@openssh.com ',
        'ssh-rsa ',
    )):
        raise RuntimeError('Git signing public key type is unsupported')


def repo_cfg(cfg: dict, alias: str) -> dict:
    repos = cfg.get('repos', {})
    if alias not in repos:
        raise ValueError(f'unknown repo alias: {alias}')
    return repos[alias]


def validate_branch(branch: str, cfg: dict):
    prefix = cfg.get('allowed_branch_prefix', 'agent/')
    if not branch.startswith(prefix):
        raise ValueError(f'branch must start with {prefix}')
    suffix = branch[len(prefix):]
    if not suffix or not BRANCH_SUFFIX_RE.match(suffix):
        raise ValueError('branch suffix must match [A-Za-z0-9._-]+')
    if '..' in branch or branch.endswith('/'):
        raise ValueError('branch contains unsafe path components')
    if branch in {'agent/main', 'agent/master', 'agent/prod', 'agent/production'}:
        raise ValueError('branch name too close to protected branch')


def validate_base_ref(ref: str) -> None:
    if not ref or not REF_NAME_RE.match(ref):
        raise ValueError(f'base branch has unsafe characters: {ref}')
    if ref.startswith('/') or ref.endswith('/') or '..' in ref or '@{' in ref:
        raise ValueError(f'base branch has unsafe path components: {ref}')


def github_clone_url(repo: dict) -> str:
    return f"https://github.com/{repo['full_name']}.git"


def upstream_clone_url(repo: dict) -> str:
    return repo.get('clone_url') or github_clone_url(repo)


def fork_repo_name(repo: dict) -> str:
    return repo.get('fork_repo') or repo['repo']


def fork_full_name(repo: dict, owner: str) -> str:
    return f'{owner}/{fork_repo_name(repo)}'


def fork_clone_url(repo: dict, owner: str) -> str:
    return f'https://github.com/{fork_full_name(repo, owner)}.git'


def pr_head_ref(repo: dict, branch: str, owner: str) -> str:
    fork = fork_full_name(repo, owner)
    if fork == repo['full_name']:
        return branch
    return f"{fork.split('/', 1)[0]}:{branch}"


def remote_head_exists(url: str, ref: str, gh_token: str) -> bool:
    try:
        cp = run(['git', 'ls-remote', '--heads', url, ref], token=gh_token, for_git=True)
    except RuntimeError:
        return False
    return bool(cp.stdout.decode().strip())


def remote_exists(url: str, gh_token: str) -> bool:
    try:
        run(['git', 'ls-remote', url, 'HEAD'], token=gh_token, for_git=True)
    except RuntimeError:
        return False
    return True


def authenticated_login(gh_token: str) -> str:
    login = run(['gh', 'api', 'user', '--jq', '.login'], token=gh_token, for_gh=True).stdout.decode().strip()
    if not login:
        raise RuntimeError('GitHub PAT authenticated but returned no login')
    return login


def owner_matches_token(owner: str, login: str) -> bool:
    return owner.lower() == login.lower()


def assert_expected_owner(cfg: dict, gh_token: str) -> str:
    expected_owner = cfg.get('expected_owner') or ''
    login = authenticated_login(gh_token)
    if expected_owner and not owner_matches_token(expected_owner, login):
        raise RuntimeError(
            'GitHub PAT owner mismatch: '
            f'token authenticates as {login!r}, but expected_owner is {expected_owner!r}. '
            f'Set robokitty_github_expected_owner to {login!r}, leave it empty, or install a PAT for {expected_owner!r}.'
        )
    return login


def github_repo_visible(full_name: str, gh_token: str) -> bool:
    try:
        out = run(
            ['gh', 'repo', 'view', full_name, '--json', 'nameWithOwner', '--jq', '.nameWithOwner'],
            token=gh_token,
            for_gh=True,
        ).stdout.decode().strip()
    except RuntimeError:
        return False
    return out.lower() == full_name.lower()


def ensure_fork(repo: dict, gh_token: str, owner: str) -> tuple[str, str, bool]:
    fork = fork_full_name(repo, owner)
    if fork == repo['full_name']:
        return fork, github_clone_url(repo), False

    fork_url = fork_clone_url(repo, owner)
    if remote_exists(fork_url, gh_token):
        return fork, fork_url, False
    if github_repo_visible(fork, gh_token):
        return fork, fork_url, False

    if not repo.get('allow_fork_create', True):
        raise RuntimeError(f'fork does not exist and fork creation is disabled: {fork}')

    fork_args = ['gh', 'repo', 'fork', repo['full_name'], '--clone=false', '--remote=false', '--default-branch-only']
    if fork_repo_name(repo) != repo['repo']:
        fork_args.extend(['--fork-name', fork_repo_name(repo)])
    run(fork_args, token=gh_token, for_gh=True)
    for _ in range(12):
        if remote_exists(fork_url, gh_token):
            return fork, fork_url, True
        if github_repo_visible(fork, gh_token):
            return fork, fork_url, True
        time.sleep(5)
    raise RuntimeError(
        f'fork was requested but did not become visible: {fork} '
        f'(git_remote_visible=false, api_visible={github_repo_visible(fork, gh_token)})'
    )


def read_prepared_file(path_arg: str, label: str, max_bytes: int) -> bytes:
    path = Path(path_arg)
    parent = path.parent
    if (
        not path.is_absolute() or
        parent.parent != PREPARED_FILE_PARENT or
        not parent.name.startswith('robokitty-submit.') or
        path.name in {'', '.', '..'}
    ):
        raise ValueError(f'{label} must be a prepared broker input file')
    parent_stat = PREPARED_FILE_PARENT.lstat()
    if not stat.S_ISDIR(parent_stat.st_mode) or stat.S_ISLNK(parent_stat.st_mode):
        raise ValueError('prepared file parent is unsafe')
    dir_flags = os.O_RDONLY
    if hasattr(os, 'O_DIRECTORY'):
        dir_flags |= os.O_DIRECTORY
    if hasattr(os, 'O_NOFOLLOW'):
        dir_flags |= os.O_NOFOLLOW
    dir_fd = os.open(parent, dir_flags)
    flags = os.O_RDONLY
    if hasattr(os, 'O_NOFOLLOW'):
        flags |= os.O_NOFOLLOW
    try:
        fd = os.open(path.name, flags, dir_fd=dir_fd)
        try:
            st = os.fstat(fd)
            if not stat.S_ISREG(st.st_mode):
                raise ValueError(f'{label} must be a regular file')
            if st.st_size > max_bytes:
                raise ValueError(f'{label} is too large')
            data = b''
            while len(data) <= max_bytes:
                chunk = os.read(fd, min(1024 * 1024, max_bytes + 1 - len(data)))
                if not chunk:
                    break
                data += chunk
            if len(data) > max_bytes:
                raise ValueError(f'{label} is too large')
            return data
        finally:
            os.close(fd)
    finally:
        os.close(dir_fd)


def materialize_body_file(path_arg: str) -> Path:
    body = read_prepared_file(path_arg, 'body-file', BODY_FILE_MAX_BYTES)
    old_umask = os.umask(0o077)
    try:
        tmpdir = Path(tempfile.mkdtemp(prefix='robokitty-body.'))
        body_file = tmpdir / 'body.md'
        body_file.write_bytes(body)
        os.chmod(body_file, 0o600)
        return body_file
    finally:
        os.umask(old_umask)


def cleanup_prepared_file(path_arg: str | None) -> None:
    if not path_arg:
        return
    path = Path(path_arg)
    if path.is_absolute() and (
        str(path).startswith(PREPARED_FILE_PREFIX) or
        str(path).startswith(REPO_SYNC_FILE_PREFIX)
    ):
        shutil.rmtree(path.parent, ignore_errors=True)


def json_out(obj: dict):
    print(json.dumps(obj, indent=2, sort_keys=True))


def read_audit_lines(limit: int) -> list[str]:
    if not AUDIT_LOG.exists() and not AUDIT_LOG.is_symlink():
        if AUDIT_CACHE_DIR.exists() or AUDIT_CACHE_DIR.is_symlink() or AUDIT_DIR.exists() or AUDIT_DIR.is_symlink():
            audit_dir_fd = open_audit_dir(create=False)
            os.close(audit_dir_fd)
        return []
    audit_dir_fd = open_audit_dir(create=False)
    flags = os.O_RDONLY
    if hasattr(os, 'O_NOFOLLOW'):
        flags |= os.O_NOFOLLOW
    try:
        fd = os.open(AUDIT_LOG.name, flags, dir_fd=audit_dir_fd)
    except OSError as ex:
        os.close(audit_dir_fd)
        raise ValueError(f'audit log is unsafe: {ex}') from ex
    try:
        st = os.fstat(fd)
        if not stat.S_ISREG(st.st_mode):
            raise ValueError('audit log is not a regular file')
        if st.st_uid != os.geteuid():
            raise ValueError('audit log owner is unsafe')
        if stat.S_IMODE(st.st_mode) != 0o600:
            raise ValueError('audit log permissions must be 0600')
        with os.fdopen(fd, 'r', encoding='utf-8') as fh:
            fd = -1
            return list(deque(fh, maxlen=limit))
    finally:
        if fd >= 0:
            os.close(fd)
        os.close(audit_dir_fd)


def cmd_audit(args) -> int:
    ensure_json_format(args)
    entries = []
    for line in read_audit_lines(args.limit):
        line = line.strip()
        if not line:
            continue
        try:
            entries.append(json.loads(line))
        except json.JSONDecodeError:
            entries.append({'parse_error': True})
    json_out({
        'ok': True,
        'audit_log': str(AUDIT_LOG),
        'count': len(entries),
        'entries': entries,
    })
    return 0


def cmd_status(args) -> int:
    ensure_json_format(args)
    cfg = load_config()
    repo = repo_cfg(cfg, args.repo)
    ok = bool(repo.get('allow_push') and repo.get('allow_pr_create'))
    gh_token = token()
    validate_signing_material()
    login = authenticated_login(gh_token)
    expected_owner = cfg.get('expected_owner') or ''
    expected_owner_matches_token = bool(not expected_owner or owner_matches_token(expected_owner, login))
    default_branch = repo.get('default_branch', 'main')
    upstream_visible = remote_head_exists(upstream_clone_url(repo), f'refs/heads/{default_branch}', gh_token)
    fork = fork_full_name(repo, login)
    fork_git_visible = remote_exists(fork_clone_url(repo, login), gh_token) if fork != repo['full_name'] else upstream_visible
    fork_api_visible = github_repo_visible(fork, gh_token) if fork != repo['full_name'] else upstream_visible
    json_out({
        'ok': ok and upstream_visible and expected_owner_matches_token,
        'repo': repo['full_name'],
        'fork': fork,
        'broker': 'configured',
        'auth': 'third-identity-pat',
        'authenticated_login': login,
        'contribution_owner': login,
        'expected_owner': expected_owner or None,
        'expected_owner_matches_token': expected_owner_matches_token,
        'commit_signing_enabled': SIGN_COMMITS,
        'signing_key': str(SIGNING_PUBLIC_KEY) if SIGN_COMMITS else None,
        'default_branch_visible': upstream_visible,
        'brokered_sync': bool(repo.get('brokered_sync')),
        'local_path': repo.get('path'),
        'source_path': repo.get('source_path'),
        'fork_visible': fork_git_visible or fork_api_visible,
        'fork_git_visible': fork_git_visible,
        'fork_api_visible': fork_api_visible,
        'allowed_base_branches': repo.get('allowed_base_branches', []),
    })
    return 0


def repo_sync_branches(repo: dict) -> list[str]:
    branches: list[str] = []
    for branch in [repo.get('default_branch', 'main'), *repo.get('allowed_base_branches', [])]:
        branch = str(branch)
        validate_base_ref(branch)
        if branch not in branches:
            branches.append(branch)
    return branches


def make_repo_sync_exchange_dir() -> Path:
    try:
        st = PREPARED_FILE_PARENT.lstat()
    except OSError as ex:
        raise RuntimeError(f'broker exchange directory is unavailable: {ex}') from ex
    if stat.S_ISLNK(st.st_mode) or not stat.S_ISDIR(st.st_mode):
        raise RuntimeError('broker exchange path must be a real directory')
    path = Path(tempfile.mkdtemp(prefix='robokitty-sync.', dir=str(PREPARED_FILE_PARENT)))
    os.chmod(path, 0o770)
    return path


def cmd_repo_sync(args) -> int:
    ensure_json_format(args)
    cfg = load_config()
    repo = repo_cfg(cfg, args.repo)
    if not repo.get('brokered_sync'):
        raise ValueError('repo is not configured for brokered sync')
    gh_token = token()
    assert_expected_owner(cfg, gh_token)
    branches = repo_sync_branches(repo)
    tmp = Path(tempfile.mkdtemp(prefix='robokitty-repo-sync.'))
    exchange: Path | None = None
    try:
        bare = tmp / 'repo.git'
        run(['git', 'init', '--bare', str(bare)])
        run(['git', '-C', str(bare), 'remote', 'add', 'origin', upstream_clone_url(repo)])
        synced_refs: list[str] = []
        for branch in branches:
            remote_ref = f'refs/remotes/origin/{branch}'
            run(
                ['git', '-C', str(bare), 'fetch', '--no-tags', 'origin', f'refs/heads/{branch}:{remote_ref}'],
                token=gh_token,
                for_git=True,
            )
            synced_refs.append(remote_ref)
            if branch == repo.get('default_branch', 'main'):
                head_ref = f'refs/heads/{branch}'
                run(['git', '-C', str(bare), 'update-ref', head_ref, remote_ref])
                synced_refs.append(head_ref)

        refs = run([
            'git', '-C', str(bare), 'for-each-ref', '--format=%(refname)',
            'refs/heads', 'refs/remotes/origin',
        ]).stdout.decode().splitlines()
        if not refs:
            raise RuntimeError('brokered sync produced no refs')

        exchange = make_repo_sync_exchange_dir()
        bundle_file = exchange / 'repo.bundle'
        run(['git', '-C', str(bare), 'bundle', 'create', str(bundle_file), *refs])
        os.chmod(bundle_file, 0o660)
        json_out({
            'ok': True,
            'repo': repo['full_name'],
            'alias': repo['alias'],
            'bundle_file': str(bundle_file),
            'default_branch': repo.get('default_branch', 'main'),
            'allowed_base_branches': repo.get('allowed_base_branches', []),
            'synced_refs': synced_refs,
            'path': repo['path'],
            'source_path': repo.get('source_path'),
        })
        return 0
    except Exception:
        if exchange is not None:
            shutil.rmtree(exchange, ignore_errors=True)
        raise
    finally:
        shutil.rmtree(tmp, ignore_errors=True)


def cmd_submit(args) -> int:
    ensure_json_format(args)
    cfg = load_config()
    repo = repo_cfg(cfg, args.repo)
    if not repo.get('allow_push') or not repo.get('allow_pr_create'):
        raise ValueError('repo does not allow push/pr creation')
    validate_branch(args.branch, cfg)
    if args.base not in repo.get('allowed_base_branches', []):
        raise ValueError(f'base branch not allowed: {args.base}')
    if not args.patch_file:
        raise ValueError('submit must be invoked through the githubctl wrapper')
    patch = read_prepared_file(args.patch_file, 'patch-file', PATCH_FILE_MAX_BYTES)
    if not patch.strip():
        raise ValueError('empty diff; nothing to submit')
    body_file = materialize_body_file(args.body_file)

    gh_token = token()
    validate_signing_material()
    contribution_owner = assert_expected_owner(cfg, gh_token)
    clone_url = upstream_clone_url(repo)
    tmp = Path(tempfile.mkdtemp(prefix='robokitty-submit.'))
    try:
        run(
            ['git', 'clone', '--no-tags', '--depth', '1', '--branch', args.base, clone_url, str(tmp / 'repo')],
            token=gh_token,
            for_git=True,
        )
        clean = tmp / 'repo'

        run(['git', '-C', str(clean), 'checkout', '-b', args.branch])
        run(['git', '-C', str(clean), 'apply', '--index', '--binary'], input_bytes=patch)
        changed_paths = run(
            ['git', '-C', str(clean), 'diff', '--cached', '--name-only']
        ).stdout.decode().splitlines()
        if not cfg.get('allow_workflow_changes') and any(p.startswith('.github/workflows/') for p in changed_paths):
            raise ValueError('changes under .github/workflows are denied in P0')
        run(['git', '-C', str(clean), 'config', 'user.name', '{{ robokitty_git_user_name }}'])
        run(['git', '-C', str(clean), 'config', 'user.email', '{{ robokitty_git_user_email }}'])
        commit_args = ['git', '-C', str(clean), '-c', 'core.hooksPath=/dev/null']
        if SIGN_COMMITS:
            run(['git', '-C', str(clean), 'config', 'gpg.format', 'ssh'])
            run(['git', '-C', str(clean), 'config', 'user.signingkey', str(SIGNING_PUBLIC_KEY)])
            run(['git', '-C', str(clean), 'config', 'commit.gpgsign', 'true'])
            commit_args.extend(['commit', '-S', '-m', args.title])
        else:
            commit_args.extend(['commit', '-m', args.title])
        run(commit_args)
        if SIGN_COMMITS:
            commit_object = run(['git', '-C', str(clean), 'cat-file', 'commit', 'HEAD']).stdout.decode(errors='replace')
            if '\ngpgsig ' not in commit_object and not commit_object.startswith('gpgsig '):
                raise RuntimeError('broker commit was not signed')
        push_full_name, push_url, created_fork = ensure_fork(repo, gh_token, contribution_owner)
        run(
            [
                'git', '-C', str(clean), '-c', 'core.hooksPath=/dev/null',
                'push', '--no-verify', push_url, f'HEAD:refs/heads/{args.branch}',
            ],
            token=gh_token,
            for_git=True,
        )

        head = pr_head_ref(repo, args.branch, contribution_owner)
        existing = run(
            [
                'gh', 'pr', 'list', '--repo', repo['full_name'], '--head', head,
                '--json', 'number,url', '--jq', '.[0] // {}',
            ],
            token=gh_token,
            for_gh=True,
        ).stdout.decode().strip()
        existing_obj = json.loads(existing or '{}')
        if existing_obj.get('number'):
            json_out({
                'ok': True,
                'repo': repo['full_name'],
                'fork': push_full_name,
                'head': head,
                'branch': args.branch,
                'base': args.base,
                'pr_number': existing_obj['number'],
                'pr_url': existing_obj.get('url'),
                'created': False,
                'fork_created': created_fork,
            })
            return 0

        gh_args = [
            'gh', 'pr', 'create', '--repo', repo['full_name'], '--head', head,
            '--base', args.base, '--title', args.title, '--body-file', str(body_file),
        ]
        if args.draft:
            gh_args.append('--draft')
        if not cfg.get('maintainer_can_modify'):
            gh_args.append('--no-maintainer-edit')
        pr_url = run(gh_args, token=gh_token, for_gh=True).stdout.decode().strip()
        json_out({
            'ok': True,
            'repo': repo['full_name'],
            'fork': push_full_name,
            'head': head,
            'branch': args.branch,
            'base': args.base,
            'pr_url': pr_url,
            'created': True,
            'fork_created': created_fork,
            'draft': bool(args.draft),
        })
        return 0
    finally:
        shutil.rmtree(tmp, ignore_errors=True)
        shutil.rmtree(body_file.parent, ignore_errors=True)
        cleanup_prepared_file(args.patch_file)
        cleanup_prepared_file(args.body_file)


def cmd_pr_view(args) -> int:
